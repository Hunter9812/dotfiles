# [Default config](https://github.com/eXeC64/imv/blob/2144bea537bff9defc81c34517a939bf361fd736/files/imv_config)
# [Manual](https://man.archlinux.org/man/imv.5)

[options]
overlay_font = Monospace:12
# Suppress built-in key bindings, and specify them explicitly in this config file.
suppress_default_binds = true

[aliases]
# Define aliases here. Any arguments passed to an alias are appended to the command.
# alias = command to run

[binds]
q = quit

#= Image navigation
<Right> = next
<Left> = prev
<bracketright> = next
<bracketleft> = prev
<Ctrl+f> = next
<Ctrl+b> = prev
<Ctrl+h> = next
<Ctrl+l> = prev
gg = goto 1
<Shift+G> = goto -1

#= Panning
j = pan 0 -50
k = pan 0 50
h = pan 50 0
l = pan -50 0

#= Zooming
<Up> = zoom 1
<Down> = zoom -1
<Shift+plus> = zoom 1
<minus> = zoom -1
i = zoom 1
o = zoom -1
= = reset

# Rotate Clockwise by 90 degrees
r = rotate by 90
e = rotate by 270

#= Other commands
f = fullscreen
<F11> = fullscreen
d = overlay
<Ctrl+g> = overlay
yy = exec echo $imv_current_file | wl-copy
c = center
s = scaling next
<Shift+S> = upscaling next
a = zoom actual

#= Gif playback
<period> = next_frame
<space> = toggle_playing

#= Slideshow control
t = slideshow +1
<Shift+T> = slideshow -1
